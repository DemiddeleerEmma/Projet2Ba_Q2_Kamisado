##===========Serveur TCP===========
#Repondre aux requêtes PING et PLAY
def start_serveur():
    def handle_client(client,adresse):
        with client:
            data = client.recv(2048).decode().strip()

            if not data:
                return
            
            req = json.loads(data)

            if req["request"] == "ping":
                res = "response" == "pong"
                client.sendall((json.dumps(res) + "\n").encode())

            elif req["request"] == "play":
               ##REPONSE SELON NOS FONCTIONS
               pass
    
    def loop():
    s = socket.socket()
    s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    s.bind(("0.0.0.0", PORT))
    s.listen()
    
    while True:
        client, adresse = s.accept()  # On accepte la connexion depuis s
        threading.Thread(target=handle_client, args=(client, adresse), daemon=True).start()
        
    threading.Thread(target=loop, daemon=True).start()
        

